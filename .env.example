# ─────────────────────────────────────────────
# Copia este fichero como .env.local para desarrollo
# En Vercel, añade estas variables en Project Settings → Environment Variables
# ─────────────────────────────────────────────

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Productos tarjeta regalo (https://dashboard.stripe.com/products)
STRIPE_PRICE_50=price_...
STRIPE_PRICE_100=price_...
STRIPE_PRICE_200=price_...

# Supabase (https://supabase.com/dashboard/project/tu-proyecto/settings/api)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_...

# Admin panel
ADMIN_PASSWORD=tu_contraseña_segura_aqui

# URL pública de la web (sin barra final)
SITE_URL=https://esteticavelasegala.com

# ── Webhook Stripe ──
# URL del endpoint en producción:
# https://estetica-velasegala.vercel.app/api/webhook
# Evento: checkout.session.completed
# El whsec_... se obtiene al crear el webhook en Stripe Dashboard → Developers → Webhooks
